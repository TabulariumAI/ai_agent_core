API_KEY=client_name:api_key #Set your API key here. The format should be "client_name:api_key". It will be provided by the service provider.
CALLBACK_URL="http://<agent_public_host>/callback" #Callback URL for receiving asynchronous responses from the API. It should be a public endpoint on your server that can handle POST requests.
SESSION_URL="https://<session_service_host>/v1" #Set the base URL for all API requests. It will be provided by the service provider.
INDEX_URL="https://<index_service_host>/v1" #Set the base URL for all API requests. It will be provided by the service provider.
FEEDBACK_URL="https://<feedback_service_host>/v1" #Set the base URL for all API requests. It will be provided by the service provider.
COMPUTE_URL="https://<compute_service_host>/v1" #Set the base URL for all API requests. It will be provided by the service provider.
RECORD_URL="https://<record_service_host>/v1" #Set the base URL for all API requests. It will be provided by the service provider.
REDACT_URL="https://<redact_service_host>/v1" #Set the base URL for all API requests. It will be provided by the service provider.
REPROCESS_URL="https://<reprocess_service_host>/v1" #Set the base URL for all API requests. It will be provided by the service provider.
RECORD_FORMAT=tiff #Set the default format for auto-recorded documents ("pdf" or "tiff"). An empty or incorrect value means both formats will be used.
REDACT_FORMAT=tiff #Set the default format for auto-redacted documents ("pdf" or "tiff"). An empty or incorrect value means both formats will be used.
