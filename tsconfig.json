{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "rootDir": "./src",
        "outDir": "./dist",
        "moduleResolution": "node",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "types": ["node", "jest"],
        "ignoreDeprecations": "5.0"
    },

    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "tests",
        "src/tests"
    ]
}